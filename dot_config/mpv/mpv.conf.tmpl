
# cookies (for yt-dlp / streaming)
cookies=yes
ytdl-raw-options=cookies-from-browser=firefox:{{ .chezmoi.homeDir }}\scoop\persist\zen-browser\profile

#Profile which sets some quality settings (Recommended)
profile=high-quality
### Audio and Subtitles ###

slang=en,eng,English
alang=en,eng

sub-auto=all
sub-fix-timing=yes
sub-file-paths=sub;subs;subtitles
sub-file-paths-append=subtitles
demuxer-mkv-subtitle-preroll=yes

sub-blur=0.5
sub-scale=0.7
sub-margin-y=60
sub-color='#d6ffffff'
sub-shadow-offset=5.0
sub-font=Clear Sans Bold
sub-back-color='#00000000'
sub-shadow-color='#00000000'
sub-outline-color='#266a678c'
sub-ass-override=yes
blend-subtitles=yes

#Default volume of the player
volume=50
volume-max=100
audio-file-auto=fuzzy
audio-normalize-downmix=yes


### General ###

keep-open=yes
save-position-on-quit=yes
ontop=yes
#Start mpv with a % smaller resolution of your screen
autofit=30%

### uosc ###

osc=no
osd-bar=no
border=no

#Video output driver
#See: https://github.com/mpv-player/mpv/wiki/GPU-Next-vs-GPU
vo=gpu-next
