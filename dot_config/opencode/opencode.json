{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "shell": "nu",
  "small_model": "openrouter/openrouter/free",
  "provider": {
    "openrouter": {
      "models": {
        "anthropic/claude-sonnet-4.6": {
          "variants": {
            "thinking": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "fast": {
              "disabled": true
            }
          }
        },
        "anthropic/claude-haiku-4.5": {
          "variants": {
            "thinking": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "fast": {
              "disabled": true
            }
          }
        }
      }
    }
  },

  "share": "disabled",

  "formatter": {
    "prettier": {
      "disabled": true
    }
  },

  "default_agent": "plan",

  "tool_output": { "max_lines": 150, "max_bytes": 6000 },

  "compaction": {
    "auto": true,
    "tail_turns": 15
  },

  "watcher": {
    "ignore": [".git/**"]
  },

  "plugin": []
}
