{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": true,

  "provider": {
    "anthropic": {
      "models": {
        "anthropic/claude-opus-4-6": {
          "variants": {
            "thinking": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "fast": {
              "disabled": true
            }
          }
        },
        "anthropic/claude-sonnet-4-6": {
          "variants": {
            "thinking": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "fast": {
              "disabled": true
            }
          }
        }
      }
    }
  },

  "tools": {
    "write": false,
    "bash": false
  },

  "share": "disabled",

  "formatter": {
    "prettier": {
      "disabled": true
    }
  },

  "default_agent": "plan",

  "permission": {
    "edit": "ask",
    "bash": "ask"
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "watcher": {
    "ignore": [".git/**"]
  },

  "command": {},
  "mcp": {}
}
