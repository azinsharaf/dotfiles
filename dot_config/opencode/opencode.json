{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "shell": "nu",
  "small_model": "openrouter/openrouter/free",
  "provider": {
    "openrouter": {
      "models": {
        "anthropic/claude-sonnet-4.6": {
          "variants": {
            "thinking": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "fast": {
              "disabled": true
            }
          }
        },
        "anthropic/claude-haiku-4.5": {
          "variants": {
            "thinking": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "fast": {
              "disabled": true
            }
          }
        }
      }
    }
  },

  "share": "disabled",

  "formatter": {
    "prettier": {
      "disabled": false
    }
  },

  "default_agent": "plan",

  "tool_output": { "max_lines": 150, "max_bytes": 6000 },

  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000,
      "max_base64_bytes": 5242880
    }
  },

  "snapshot": true,

  "compaction": {
    "auto": true,
    "tail_turns": 15
  },

  "watcher": {
    "ignore": [".git/**"]
  },

  "mcp": {
    "ticktick": {
      "type": "remote",
      "url": "https://mcp.ticktick.com",
      "enabled": true
    }
  },

  "plugin": []
}
