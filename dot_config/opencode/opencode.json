{
  "$schema": "https://opencode.ai/config.json",
  "tui": {
    "scroll_speed": 3
  },

  "theme": "catppuccin",
  "formatter": {
    "prettier": {
      "disabled": true
    }
  },

  "permission": {
    "edit": "deny"
  },

  "tools": {
    "read": true,
    "edit": true,
    "write": false,
    "bash": true,
    "webfetch": true,
    "grep": true,
    "glob": true,
    "list": true,
    "patch": true
  },

  "share": "disabled",

  "agent": {
    "plan": {
      "tools": {
        "write": false,
        "bash": false
      }
    },

    "build": {
      "permission": {
        "edit": "ask",
        "bash": { "git push": "ask" }
      }
    }
  }
}
